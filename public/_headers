# Hashed assets built by Astro (immutable)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static assets in public/
/favicon.svg
  Cache-Control: public, max-age=86400

/favicon.png
  Cache-Control: public, max-age=86400

/logo.svg
  Cache-Control: public, max-age=86400

/og.jpg
  Cache-Control: public, max-age=86400

/background.jpg
  Cache-Control: public, max-age=86400

/pp.jpg
  Cache-Control: public, max-age=86400
