---
import Layout from "../../layouts/Layout.astro";
import GridBackground from "../../components/GridBackground";
import Header from "../../components/Header";
import ImVector from "../../components/tools/ImVector";
import { t, getLocalizedPath } from "../../lib/i18n";

const locale = "en" as const;
---

<Layout
  title={t(locale, "seo.imvector.title")}
  description={t(locale, "seo.imvector.description")}
  locale={locale}
>
  <GridBackground client:load />
  <Header client:load locale={locale} />
  <main class="relative z-10 mx-auto max-w-5xl px-4 pt-20 pb-4 md:px-6 h-svh flex flex-col">
    <a href={getLocalizedPath(locale, "/tools")} class="mb-6 inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground">
      {t(locale, "imvector.backToTools")}
    </a>
    <h1 class="mb-2 text-2xl font-bold tracking-tight text-foreground md:text-3xl">
      {t(locale, "imvector.heading")}
    </h1>
    <p class="mb-6 text-sm text-muted-foreground">
      {t(locale, "imvector.description")}
    </p>
    <div class="flex-1 min-h-0">
      <ImVector client:only="react" locale={locale} />
    </div>
    <p class="py-4 text-xs text-muted-foreground/50">
      Powered by <a href="https://www.visioncortex.org/vtracer/" class="underline hover:text-muted-foreground" target="_blank" rel="noopener noreferrer">VTracer</a> & WebAssembly
    </p>
  </main>
</Layout>
