---
import Layout from "../layouts/Layout.astro";
import GridBackground from "../components/GridBackground";
import Header from "../components/Header";
import { t, getLocaleFromUrl, getLocalizedPath, type Locale } from "../lib/i18n";

const locale: Locale = getLocaleFromUrl(Astro.url);
const homeHref = getLocalizedPath(locale, "/");
---

<Layout title={t(locale, "404.title")} noindex={true} locale={locale}>
  <GridBackground client:load />
  <Header client:load locale={locale} />
  <main class="relative z-10 flex min-h-svh items-center justify-center text-center px-4">
    <div>
      <p class="mb-3 text-6xl font-bold text-primary">404</p>
      <h1 class="mb-3 text-xl font-semibold text-foreground">{t(locale, "404.heading")}</h1>
      <p class="mb-6 text-sm text-muted-foreground">{t(locale, "404.description")}</p>
      <a href={homeHref} class="inline-flex items-center gap-2 bg-primary px-5 py-2 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90">
        {t(locale, "404.goHome")}
      </a>
    </div>
  </main>
</Layout>
